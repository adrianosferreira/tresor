# Copy to deploy/.env (or repo root — run compose from deploy/ with --env-file)
#
# Local development — defaults below work with `docker compose up -d` from deploy/
# Production — set strong DB_PASSWORD and JWT_SECRET; set PUBLIC_URL to your public origin

# Database
DB_PASSWORD=tresor_dev_password

# Server
JWT_SECRET=dev-jwt-secret-change-in-production

# Browser origin allowed by the API (CORS). Use http://localhost when using Docker only.
# Set to http://localhost:5173 if you run the Vite dev server on the host instead of `web`.
CORS_ORIGIN=http://localhost

# Public URL (documentation / future TLS blocks in Caddyfile)
PUBLIC_URL=http://localhost

# Client build: leave empty behind Caddy (SPA uses `/api/v1/...` on same origin).
# Set to http://localhost:8080 only if you need an absolute API URL in the built bundle.
VITE_API_URL=

# Host port for direct API access (CLI, debugging)
API_PORT=8080

# Caddy
HTTP_PORT=80
HTTPS_PORT=443

# Optional: domain for TLS (production) — see deploy/Caddyfile
# PUBLIC_DOMAIN=vault.example.com
